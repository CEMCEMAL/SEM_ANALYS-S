def _sep(parent, vertical=False):
    kw = dict(bg=C["sep"], width=1) if vertical else dict(bg=C["sep"], height=1)
    return tk.Frame(parent, **kw)


class MetricCard(tk.Frame):
    def __init__(self, parent, label, unit="", accent=None, **kw):
        super().__init__(parent, bg=C["bg_card"],
                         highlightbackground=C["border"], highlightthickness=1, **kw)
        self._accent = accent or C["teal"]
        tk.Frame(self, bg=self._accent, height=2).pack(fill="x")
        inner = tk.Frame(self, bg=C["bg_card"])
        inner.pack(fill="both", expand=True, padx=12, pady=8)
        self._var   = tk.StringVar(value="--")
        self._lbl_v = tk.Label(inner, textvariable=self._var,
                               font=(F_NUM, 15, "bold"), fg=C["text_hi"], bg=C["bg_card"])
        self._lbl_v.pack(anchor="w")
        self._lbl_u = tk.Label(inner, text=unit, font=FT["small"],
                               fg=self._accent, bg=C["bg_card"])
        self._lbl_u.pack(anchor="w")
        self._lbl_l = tk.Label(inner, text=label, font=FT["small"],
                               fg=C["text_lo"], bg=C["bg_card"])
        self._lbl_l.pack(anchor="w", pady=(3, 0))

    def set(self, v):
        self._var.set(str(v))

    def relabel(self, label, unit):
        self._lbl_l.configure(text=label)
        self._lbl_u.configure(text=unit)


class ScrollFrame(tk.Frame):
    def __init__(self, parent, bg=None, **kw):
        bg = bg or C["bg_panel"]
        super().__init__(parent, bg=bg, **kw)
        self._cv = tk.Canvas(self, bg=bg, highlightthickness=0, bd=0)
        self._sb = tk.Scrollbar(self, orient="vertical", command=self._cv.yview)
        self._cv.configure(yscrollcommand=self._sb.set)
        self._sb.pack(side="right", fill="y")
        self._cv.pack(side="left", fill="both", expand=True)
        self.inner = tk.Frame(self._cv, bg=bg)
        self._win  = self._cv.create_window((0, 0), window=self.inner, anchor="nw")
        self.inner.bind("<Configure>", lambda e: self._cv.configure(
            scrollregion=self._cv.bbox("all")))
        self._cv.bind("<Configure>", lambda e: self._cv.itemconfig(
            self._win, width=e.width))
        for w in (self._cv, self.inner):
            w.bind("<MouseWheel>", lambda e: self._cv.yview_scroll(
                int(-1 * (e.delta / 120)), "units"))


class ZoomCanvas(tk.Canvas):
    """Canvas with mouse-wheel zoom and drag-to-pan. Double-click resets view."""

    def __init__(self, parent, **kw):
        super().__init__(parent, **kw)
        self._zoom      = 1.0
        self._pan_x     = 0
        self._pan_y     = 0
        self._drag_start: Optional[Tuple[int, int]] = None
        self._img_id    = None
        self._pil_orig:  Optional[Image.Image] = None
        self._tk_ref    = None

        self.bind("<MouseWheel>",     self._on_wheel)
        self.bind("<Button-4>",       self._on_wheel)    # Linux scroll up
        self.bind("<Button-5>",       self._on_wheel)    # Linux scroll down
        self.bind("<ButtonPress-1>",  self._drag_start_ev)
        self.bind("<B1-Motion>",      self._drag_move)
        self.bind("<ButtonRelease-1>",self._drag_end)
        self.bind("<Double-Button-1>",self._reset_view)
        self.bind("<Configure>",      self._on_resize)

    def show_pil(self, pil: Image.Image):
        self._pil_orig = pil.copy()
        self._zoom     = 1.0
        self._pan_x    = 0
        self._pan_y    = 0
        self._render()

    def _render(self):
        if self._pil_orig is None:
            return
        cw = self.winfo_width()  or 800
        ch = self.winfo_height() or 400
        iw = max(1, int(self._pil_orig.width  * self._zoom))
        ih = max(1, int(self._pil_orig.height * self._zoom))
        resized     = self._pil_orig.resize((iw, ih), Image.LANCZOS)
        self._tk_ref = ImageTk.PhotoImage(resized)
        self.delete("all")
        cx = cw // 2 + self._pan_x
        cy = ch // 2 + self._pan_y
        self._img_id = self.create_image(cx, cy, image=self._tk_ref, anchor="center")

    def _on_wheel(self, e):
        if self._pil_orig is None:
            return
        delta = getattr(e, "delta", 0)
        if e.num == 4:
            delta = 120
        elif e.num == 5:
            delta = -120
        factor = 1.1 if delta > 0 else 0.9
        self._zoom = max(0.1, min(self._zoom * factor, 20.0))
        self._render()

    def _drag_start_ev(self, e):
        self._drag_start = (e.x, e.y)

    def _drag_move(self, e):
        if self._drag_start and self._pil_orig:
            dx = e.x - self._drag_start[0]
            dy = e.y - self._drag_start[1]
            self._pan_x += dx
            self._pan_y += dy
            self._drag_start = (e.x, e.y)
            self._render()

    def _drag_end(self, e):
        self._drag_start = None

    def _reset_view(self, e=None):
        self._zoom, self._pan_x, self._pan_y = 1.0, 0, 0
        self._render()

    def _on_resize(self, e):
        self._render()


