    # ── PLACEHOLDER ───────────────────────────────────────────────────────────
    def _placeholder(self):
        self.img_canvas.update_idletasks()
        w = self.img_canvas.winfo_width()  or 800
        h = self.img_canvas.winfo_height() or 400
        self.img_canvas.delete("all")
        self.img_canvas.create_rectangle(0, 0, w, h, fill=C["bg_card"], outline="")
        for x in range(0, w, 44): self.img_canvas.create_line(x,0,x,h, fill=C["sep"])
        for y in range(0, h, 44): self.img_canvas.create_line(0,y,w,y, fill=C["sep"])
        cx, cy = w//2, h//2
        self.img_canvas.create_text(cx, cy-16, text="\u2610",
                                    font=(F_UI,34), fill=C["border"])
        self.img_canvas.create_text(cx, cy+22, font=FT["small"],
                                    fill=C["text_lo"], text=self.t("ph_line1"))
        self.img_canvas.create_text(cx, cy+40, font=FT["small"],
                                    fill=C["sep"], text=self.t("ph_line2"))

    def _load_preview(self, path):
        try:
            pil = Image.open(path)
            self.img_canvas.update_idletasks()
            cw = self.img_canvas.winfo_width()  or 800
            ch = self.img_canvas.winfo_height() or 400
            pil.thumbnail((cw-4,ch-4), Image.LANCZOS)
            self._tk_img = ImageTk.PhotoImage(pil)
            self.img_canvas.delete("all")
            self.img_canvas.create_rectangle(0,0,cw,ch, fill=C["bg_card"], outline="")
            self.img_canvas.create_image(cw//2, ch//2,
                                         image=self._tk_img, anchor="center")
            info = f"  {Path(path).name}  \u00b7  {pil.size[0]} x {pil.size[1]} px"
            self.img_canvas.create_rectangle(0,0,cw,22, fill="#00000077", outline="")
            self.img_canvas.create_text(10, 11, anchor="w",
                                        text=info, font=FT["mono_s"], fill=C["text_lo"])
        except Exception as e:
            self._log_add(self.t("log_prev_err") + str(e), "err")

    def _show_cv2(self, bgr):
        rgb = cv2.cvtColor(bgr, cv2.COLOR_BGR2RGB)
        pil = Image.fromarray(rgb)
        self.img_canvas.update_idletasks()
        cw = self.img_canvas.winfo_width()  or 800
        ch = self.img_canvas.winfo_height() or 400
        pil.thumbnail((cw-4,ch-4), Image.LANCZOS)
        self._tk_img = ImageTk.PhotoImage(pil)
        self.img_canvas.delete("all")
        self.img_canvas.create_rectangle(0,0,cw,ch, fill=C["bg_card"], outline="")
        self.img_canvas.create_image(cw//2, ch//2,
                                     image=self._tk_img, anchor="center")

    # ── BROWSE ────────────────────────────────────────────────────────────────
    @property
    def _ftypes(self):
        return [(self.t("browse_ftypes"),
                 "*.png *.jpg *.jpeg *.tif *.tiff *.bmp *.avif *.webp"),
                ("*", "*.*")]

    def _browse1(self):
        p = filedialog.askopenfilename(title=self.t("browse_primary"),
                                       filetypes=self._ftypes)
        if p:
            self.img_path.set(p)
            self._load_preview(p)
            self._log_add(self.t("log_loaded") + Path(p).name, "ok")

    def _browse2(self):
        p = filedialog.askopenfilename(title=self.t("browse_compare"),
                                       filetypes=self._ftypes)
        if p:
            self.img_path2.set(p)
            self._log_add(self.t("log_cmp_loaded") + Path(p).name, "ok")

    # ── RUN ───────────────────────────────────────────────────────────────────
    def _run(self):
        path = self.img_path.get().strip()
        mode = self.mode_var.get()
        if not path and mode != "Comparison":
            messagebox.showwarning(self.t("dlg_no_img"), self.t("dlg_no_img_msg")); return
        if mode == "Comparison" and (not self.img_path.get() or not self.img_path2.get()):
            messagebox.showwarning(self.t("dlg_two_img"), self.t("dlg_two_img_msg")); return
        self.progress.start(8)
        self._set_status(self.t("status_analyzing"), C["amber"])
        threading.Thread(target=self._thread, daemon=True).start()

    def _thread(self):
        try:
            mode = self.mode_var.get()
            path = self.img_path.get().strip()
            if mode != "Comparison": self.engine.load_image(path)
            if mode == "Porosity":
                r = self.engine.analyze_porosity(self.thresh_var.get(), self.min_pore_var.get())
                self.after(0, lambda: self._disp_porosity(r))
            elif mode == "Fouling Layer":
                r = self.engine.analyze_fouling(self.side_var.get())
                self.after(0, lambda: self._disp_fouling(r))
            elif mode == "Active Sites":
                r = self.engine.analyze_active_sites(self.cluster_var.get())
                self.after(0, lambda: self._disp_sites(r))
            elif mode == "Comparison":
                r = self.engine.compare_images(self.img_path.get(),
                                               self.img_path2.get(),
                                               self.thresh_var.get())
                self.after(0, lambda: self._disp_comparison(r))
            ts = datetime.datetime.now().strftime("%H:%M:%S")
            self._log_add(f"[{ts}] {mode}" + self.t("log_done"), "ok")
            self.after(0, lambda: self._set_status(self.t("status_done"), C["teal"]))
        except Exception as e:
            self._log_add(self.t("log_err") + str(e), "err")
            self.after(0, lambda: messagebox.showerror(self.t("dlg_err"), str(e)))
            self.after(0, lambda: self._set_status(self.t("status_error"), C["red"]))
        finally:
            self.after(0, self.progress.stop)

    # ── RESULTS TEXT ──────────────────────────────────────────────────────────
    def _rt_default(self):
        self.rt.configure(state="normal")
        self.rt.delete("1.0","end")
        self.rt.insert("end", self.t("rt_default1"), "key")
        self.rt.insert("end", self.t("rt_default2"), "key")
        self.rt.configure(state="disabled")

    def _clr_rt(self):
        self.rt.configure(state="normal"); self.rt.delete("1.0","end")

    def _rt_head(self, key):
        self.rt.insert("end", f"\n  {self.t(key)}\n  {'─'*46}\n", "hdr")

    def _rt_row(self, key, val, tag="ok"):
        self.rt.insert("end", f"  {self.t(key):<34}", "key")
        self.rt.insert("end", f"{val}\n", tag)

    # ── DISPLAY ───────────────────────────────────────────────────────────────
    def _disp_porosity(self, r):
        self._clr_rt()
        self._rt_head("hdr_por")
        self._rt_row("k_method",    r["method"].upper(), "info")
        self._rt_row("k_porosity",  f"{r['porosity_pct']:.3f} %",
                     "warn" if r["porosity_pct"] < 5 else "ok")
        self._rt_row("k_pore_count",r["pore_count"])
        self._rt_head("hdr_psd")
        self._rt_row("k_mean_diam", r["mean_diam_px"])
        self._rt_row("k_std_diam",  r["std_diam_px"])
        self._rt_row("k_min_diam",  r["min_diam_px"])
        self._rt_row("k_max_diam",  r["max_diam_px"])
        self._rt_row("k_eccentric", r["mean_eccentric"])
        self.rt.configure(state="disabled")
        self.mc["porosity"].set(f"{r['porosity_pct']:.2f}")
        self.mc["pores"].set(r["pore_count"])
        self.mc["diam"].set(f"{r['mean_diam_px']:.1f}")
        self.mc["fouling"].set("--")
        ov = self.engine.original.copy()
        ov[r["mask"]>0] = [0,175,140]
        self._show_cv2(cv2.addWeighted(self.engine.original,0.55,ov,0.45,0))
        self._plt_porosity(r)

    def _disp_fouling(self, r):
        self._clr_rt()
        self._rt_head("hdr_foul")
        self._rt_row("k_side",      r["layer_side"].upper(), "info")
        self._rt_row("k_interface", r["interface_row_px"])
        self._rt_row("k_f_px",      r["fouling_thickness_px"])
        self._rt_row("k_f_pct",     f"{r['fouling_thickness_pct']:.2f} %",
                     "warn" if r["fouling_thickness_pct"]>30 else "ok")
        self._rt_head("hdr_int")
        self._rt_row("k_l_int",   r["layer_mean_intensity"])
        self._rt_row("k_m_int",   r["membrane_mean_intensity"])
        self._rt_row("k_contrast",r["contrast_ratio"])
        self.rt.configure(state="disabled")
        self.mc["fouling"].set(r["fouling_thickness_px"])
        for k in ["porosity","pores","diam"]: self.mc[k].set("--")
        self._plt_fouling(r)

    def _disp_sites(self, r):
        self._clr_rt()
        self._rt_head("hdr_sites")
        self._rt_row("k_k",         r["cluster_count"], "info")
        self._rt_row("k_bright_cnt",r["bright_site_count"])
        self._rt_row("k_dark_cnt",  r["dark_site_count"])
        self._rt_row("k_total_cnt", r["total_site_count"])
        self._rt_head("hdr_cov")
        self._rt_row("k_bright_cov",f"{r['bright_coverage_pct']:.3f} %")
        self._rt_row("k_dark_cov",  f"{r['dark_coverage_pct']:.3f} %")
        total = r["bright_coverage_pct"]+r["dark_coverage_pct"]
        self._rt_row("k_total_cov", f"{total:.3f} %", "warn" if total<1.0 else "ok")
        self.rt.configure(state="disabled")
        self.mc["pores"].set(r["total_site_count"])
        for k in ["porosity","diam","fouling"]: self.mc[k].set("--")
        self._plt_sites(r)

    def _disp_comparison(self, r):
        self._clr_rt()
        self._rt_head("hdr_comp")
        self._rt_row("k_img1_por", f"{r['img1_porosity']:.3f}")
        self._rt_row("k_img2_por", f"{r['img2_porosity']:.3f}")
        d = r["delta_porosity"]
        self._rt_row("k_delta", f"{d:+.3f} %", "warn" if abs(d)>5 else "ok")
        self._rt_head("hdr_cnt")
        self._rt_row("k_img1_cnt",  r["img1_pore_count"])
        self._rt_row("k_img2_cnt",  r["img2_pore_count"])
        self._rt_row("k_img1_diam", r["img1_mean_diam"])
        self._rt_row("k_img2_diam", r["img2_mean_diam"])
        self.rt.configure(state="disabled")
        self.mc["porosity"].set(f"{d:+.2f}")
        self.mc["pores"].set(f"{r['img1_pore_count']} / {r['img2_pore_count']}")
        self.mc["diam"].set(f"{r['img1_mean_diam']:.1f}")
        self.mc["fouling"].set("--")
        self._plt_comparison(r)

    # ── CHARTS ────────────────────────────────────────────────────────────────
    def _ax_style(self, ax):
        ax.set_facecolor(C["bg_card"])
        ax.tick_params(colors=C["text_lo"], labelsize=7)
        for sp in ax.spines.values(): sp.set_edgecolor(C["border"])

    def _clr_fig(self):
        self.fig.clf(); self.fig.patch.set_facecolor(C["bg_card"])

    def _plt_porosity(self, r):
        self._clr_fig()
        ax1 = self.fig.add_subplot(1,2,1); ax2 = self.fig.add_subplot(1,2,2)
        ax1.imshow(r["mask"], cmap="Greens")
        ax1.set_title(self.t("ct_mask"), color=C["teal"], fontsize=9, pad=5)
        ax1.axis("off")
        if len(r["diameters"]) > 0:
            ax2.hist(r["diameters"], bins=30, color=C["teal"],
                     alpha=0.7, edgecolor=C["teal_dim"], linewidth=0.5)
            ax2.set_xlabel(self.t("ax_diam"),  color=C["text_lo"], fontsize=8)
            ax2.set_ylabel(self.t("ax_count"), color=C["text_lo"], fontsize=8)
            ax2.set_title(self.t("ct_psd"),    color=C["teal"], fontsize=9, pad=5)
        self._ax_style(ax1); self._ax_style(ax2)
        self.fig.tight_layout(pad=1.5); self.plot_cv.draw()
        self.nb.select(self.tab_c)

    def _plt_fouling(self, r):
        self._clr_fig()
        ax1 = self.fig.add_subplot(1,2,1); ax2 = self.fig.add_subplot(1,2,2)
        ax1.imshow(r["edge_map"], cmap="YlOrBr")
        ax1.axhline(r["interface_row_px"], color=C["teal"], lw=1.5, ls="--")
        ax1.set_title(self.t("ct_edge"), color=C["amber"], fontsize=9, pad=5)
        ax1.axis("off")
        prof = r["profile"]
        ax2.plot(prof, range(len(prof)), color=C["teal"], lw=1.5)
        ax2.axhline(r["interface_row_px"], color=C["amber"], lw=1.5,
                    ls="--", label=self.t("ax_interface"))
        ax2.invert_yaxis()
        ax2.set_xlabel(self.t("ax_intensity"), color=C["text_lo"], fontsize=8)
        ax2.set_ylabel(self.t("ax_row"),       color=C["text_lo"], fontsize=8)
        ax2.set_title(self.t("ct_profile"),    color=C["amber"], fontsize=9, pad=5)
        ax2.legend(fontsize=7, facecolor=C["bg_card"],
                   labelcolor=C["text_md"], framealpha=0.8)
        self._ax_style(ax1); self._ax_style(ax2)
        self.fig.tight_layout(pad=1.5); self.plot_cv.draw()
        self.nb.select(self.tab_c)

    def _plt_sites(self, r):
        self._clr_fig()
        ax1,ax2,ax3 = (self.fig.add_subplot(1,3,i) for i in (1,2,3))
        ax1.imshow(r["g_norm"], cmap="gray")
        ax1.set_title(self.t("ct_norm"),  color=C["text_md"], fontsize=9, pad=5); ax1.axis("off")
        ax2.imshow(r["bright_mask"], cmap="YlOrBr")
        ax2.set_title(f"{self.t('ct_bright')} ({r['bright_site_count']})",
                      color=C["amber"], fontsize=9, pad=5); ax2.axis("off")
        ax3.imshow(r["dark_mask"], cmap="GnBu")
        ax3.set_title(f"{self.t('ct_dark')} ({r['dark_site_count']})",
                      color=C["blue"], fontsize=9, pad=5);  ax3.axis("off")
        for ax in (ax1,ax2,ax3): self._ax_style(ax)
        self.fig.tight_layout(pad=1.5); self.plot_cv.draw()
        self.nb.select(self.tab_c)

    def _plt_comparison(self, r):
        self._clr_fig()
        ax1 = self.fig.add_subplot(1,2,1); ax2 = self.fig.add_subplot(1,2,2)
        lbls = [self.t("lbl_img1_bar"), self.t("lbl_img2_bar")]
        ax1.bar(lbls, [r["img1_porosity"],  r["img2_porosity"]],
                color=[C["teal"],C["blue"]], width=0.45, edgecolor="none")
        ax1.set_ylabel(self.t("ax_porosity"),  color=C["text_lo"], fontsize=8)
        ax1.set_title(self.t("ct_por_cmp"),    color=C["teal"], fontsize=9, pad=5)
        ax2.bar(lbls, [r["img1_pore_count"],r["img2_pore_count"]],
                color=[C["teal"],C["amber"]], width=0.45, edgecolor="none")
        ax2.set_ylabel(self.t("ax_pore_count"), color=C["text_lo"], fontsize=8)
        ax2.set_title(self.t("ct_cnt_cmp"),     color=C["amber"], fontsize=9, pad=5)
        self._ax_style(ax1); self._ax_style(ax2)
        self.fig.tight_layout(pad=1.5); self.plot_cv.draw()
        self.nb.select(self.tab_c)

    # ── EXPORT ────────────────────────────────────────────────────────────────
    def _export_csv(self):
        if not self.engine.results:
            messagebox.showinfo(self.t("dlg_no_data"), self.t("dlg_no_data_msg")); return
        path = filedialog.asksaveasfilename(defaultextension=".csv",
                                            filetypes=[("CSV","*.csv")])
        if not path: return
        import csv
        with open(path,"w",newline="",encoding="utf-8") as f:
            w = csv.writer(f)
            w.writerow([self.t("csv_param"), self.t("csv_value"), self.t("csv_module")])
            for mod, data in self.engine.results.items():
                for k,v in data.items():
                    if isinstance(v,(int,float,str,bool)): w.writerow([k,v,mod])
        self._log_add(self.t("log_csv") + path, "ok")
        messagebox.showinfo(self.t("dlg_exported"), self.t("dlg_csv_done") + path)

    def _export_pdf(self):
        if not self.engine.results:
            messagebox.showinfo(self.t("dlg_no_data"), self.t("dlg_no_data_msg")); return
        try:
            from reportlab.lib.pagesizes import A4
            from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle
            from reportlab.lib.styles import getSampleStyleSheet
            from reportlab.lib import colors
        except ImportError:
            messagebox.showerror(self.t("dlg_pkg"), self.t("dlg_pkg_msg")); return
        path = filedialog.asksaveasfilename(defaultextension=".pdf",
                                            filetypes=[("PDF","*.pdf")])
        if not path: return
        doc = SimpleDocTemplate(path, pagesize=A4)
        styles = getSampleStyleSheet(); story = []
        now = datetime.datetime.now().strftime("%Y-%m-%d  %H:%M:%S")
        story.append(Paragraph(self.t("pdf_title"), styles["Title"]))
        story.append(Paragraph(f"Generated: {now}", styles["Normal"]))
        story.append(Spacer(1,12))
        for mod, data in self.engine.results.items():
            story.append(Paragraph(self.t("pdf_module") + mod.upper(), styles["Heading2"]))
            rows = [[self.t("pdf_param"), self.t("pdf_value")]]
            for k,v in data.items():
                if isinstance(v,(int,float,str,bool)): rows.append([str(k),str(v)])
            tbl = Table(rows, colWidths=[260,200])
            tbl.setStyle(TableStyle([
                ("BACKGROUND",(0,0),(-1,0),colors.HexColor("#20242C")),
                ("TEXTCOLOR", (0,0),(-1,0),colors.HexColor("#4EC9B0")),
                ("FONTNAME",  (0,0),(-1,0),"Courier-Bold"),
                ("ROWBACKGROUNDS",(0,1),(-1,-1),
                 [colors.HexColor("#1A1D23"),colors.HexColor("#20242C")]),
                ("TEXTCOLOR", (0,1),(-1,-1),colors.HexColor("#B0B8C8")),
                ("FONTNAME",  (0,1),(-1,-1),"Courier"),
                ("FONTSIZE",  (0,0),(-1,-1),9),
                ("GRID",      (0,0),(-1,-1),0.3,colors.HexColor("#353B48")),
                ("TOPPADDING",(0,0),(-1,-1),5),("BOTTOMPADDING",(0,0),(-1,-1),5),
            ]))
            story.append(tbl); story.append(Spacer(1,14))
        doc.build(story)
        self._log_add(self.t("log_pdf") + path, "ok")
        messagebox.showinfo(self.t("dlg_exported"), self.t("dlg_pdf_done") + path)

    # ── UTILS ─────────────────────────────────────────────────────────────────
    def _reset(self):
        self.engine = AnalysisEngine()
        self.img_path.set(""); self.img_path2.set("")
        self._placeholder(); self._rt_default()
        self._clr_fig(); self.plot_cv.draw()
        for mc in self.mc.values(): mc.set("--")
        self._set_status(self.t("status_reset"), C["text_lo"])
        self._log_add(self.t("log_reset"), "ts")

    def _set_status(self, msg, col=None):
        col = col or C["text_lo"]
        self._dot.configure(fg=col)
        self._status_lbl.configure(text=f" {msg}")
        self._sb_status.configure(text=msg)

    def _log_add(self, msg, tag="ts"):
        self.log.configure(state="normal")
        self.log.insert("end", msg+"\n", tag)
        self.log.see("end")
        self.log.configure(state="disabled")


