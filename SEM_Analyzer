# ─── SEM / TEM METADATA AUTO-EXTRACTOR ──────────────────────────────────────
# Reads the info bar (bottom or top strip) of SEM/TEM images via OCR and
# automatically derives the physical scale (nm/px).
#
# Requires:  pip install pytesseract
#            + system Tesseract:  apt install tesseract-ocr  (Linux)
#                                 brew install tesseract      (macOS)
#                                 https://github.com/UB-Mannheim/tesseract (Win)
# If pytesseract is not installed, auto-detect silently returns None.
# ---------------------------------------------------------------------------

import re as _re

_SEM_PATTERNS = {
    # "View field: 10.4 µm" — the most reliable source
    "view_field": _re.compile(
        r"view\s*field[:\s]+([0-9]+[.,]?[0-9]*)\s*(nm|um|µm|\xb5m|mm|pm|'m)",
        _re.IGNORECASE,
    ),
    # standalone scale bar label: "2 µm", "500 nm"  (appears near the bar graphic)
    "scale_bar": _re.compile(
        r"\b([0-9]+[.,]?[0-9]*)\s*(nm|um|µm|\xb5m|mm)\b",
        _re.IGNORECASE,
    ),
    # "SEM MAG: 20.0 kx" / "Mag: 20000x"
    "mag": _re.compile(
        r"(?:sem\s*)?mag(?:nification)?[:\s]*([0-9]+[.,]?[0-9]*)\s*(kx|k|x)",
        _re.IGNORECASE,
    ),
    # "HV: 20.0 kV" / "SEM HV: 20.0 KV"
    "hv": _re.compile(
        r"\b(?:sem\s*)?h[tv][:\s]+([0-9]+[.,]?[0-9]*)\s*(kv|v)",
        _re.IGNORECASE,
    ),
    # "WD: 9.71 mm"
    "wd": _re.compile(
        r"\bw\.?d\.?[:\s]+([0-9]+[.,]?[0-9]*)\s*(mm|cm|m)",
        _re.IGNORECASE,
    ),
}

# OCR µm misreads (common with Tesseract on SEM fonts)
_OCR_UNIT_FIXES = {
    "pm": "µm",   # most common misread of µm
    "'m": "µm",
    "zm": "µm",
    "ym": "µm",
    "um": "µm",
    "\xb5m": "µm",
}
_UNIT_TO_NM = {"nm": 1.0, "µm": 1_000.0, "mm": 1_000_000.0}


def _fix_unit(raw: str, value: float) -> str:
    """
    Correct common OCR misreads of µm.
    Heuristic: if the corrected unit is pm but value > 0.05, treat as µm —
    because picometres at that scale are physically nonsensical for SEM.
    """
    u = _OCR_UNIT_FIXES.get(raw.lower(), raw.lower())
    if u == "pm" and value > 0.05:
        u = "µm"
    return u


def _ocr_bar(gray_strip) -> str:
    """Run Tesseract on an upscaled binarised strip."""
    try:
        import cv2 as _cv2
        import pytesseract as _tess
    except ImportError:
        return ""
    up  = _cv2.resize(gray_strip, (gray_strip.shape[1]*3, gray_strip.shape[0]*3),
                      interpolation=_cv2.INTER_CUBIC)
    _, bw = _cv2.threshold(up, 128, 255, _cv2.THRESH_BINARY)
    return _tess.image_to_string(bw, config="--psm 6")


def extract_sem_metadata(img_path: str) -> dict:
    """
    Auto-detect SEM/TEM scale from the info bar of a microscopy image.

    Returns
    -------
    dict with keys (all optional — only present when detected):
        view_field_value  float   physical image width (original unit)
        view_field_unit   str     "nm" | "µm" | "mm"
        scale_bar_value   float
        scale_bar_unit    str
        magnification     float   linear magnification (e.g. 20000)
        hv_kv             float   accelerating voltage in kV
        wd_mm             float   working distance in mm
        nm_per_px         float   ← primary calibration output
        cal_source        str     human-readable description of origin
        img_width_px      int
        raw_ocr           str     full OCR text (for debugging)
    """
    try:
        import cv2 as _cv2
    except ImportError:
        return {}

    gray = _cv2.imread(img_path, _cv2.IMREAD_GRAYSCALE)
    if gray is None:
        try:
            from PIL import Image as _PILImg
            import numpy as _np
            gray = _np.array(_PILImg.open(img_path).convert("L"))
        except Exception:
            return {}

    h, w = gray.shape
    result: dict = {"img_width_px": w}

    # Scan bottom bar (primary), then top bar (fallback)
    ocr_texts = []
    for frac_start, frac_end in [(0.86, 1.0), (0.0, 0.14)]:
        strip = gray[int(h * frac_start): int(h * frac_end), :]
        if strip.size == 0:
            continue
        txt = _ocr_bar(strip)
        ocr_texts.append(txt)
        if not result.get("raw_ocr"):
            result["raw_ocr"] = txt

        flat = txt.replace("\n", " ")

        # ── View field ───────────────────────────────────────────────────────
        m = _SEM_PATTERNS["view_field"].search(flat)
        if m and "view_field_value" not in result:
            val  = float(m.group(1).replace(",", "."))
            unit = _fix_unit(m.group(2), val)
            result["view_field_value"] = val
            result["view_field_unit"]  = unit

        # ── Scale bar label ──────────────────────────────────────────────────
        for m in _SEM_PATTERNS["scale_bar"].finditer(flat):
            val  = float(m.group(1).replace(",", "."))
            unit = _fix_unit(m.group(2), val)
            if "scale_bar_value" not in result and val > 0:
                result["scale_bar_value"] = val
                result["scale_bar_unit"]  = unit
                break

        # ── Magnification ────────────────────────────────────────────────────
        m = _SEM_PATTERNS["mag"].search(flat)
        if m and "magnification" not in result:
            val  = float(m.group(1).replace(",", "."))
            suf  = m.group(2).lower()
            result["magnification"] = val * 1000 if "k" in suf else val

        # ── HV ───────────────────────────────────────────────────────────────
        m = _SEM_PATTERNS["hv"].search(flat)
        if m and "hv_kv" not in result:
            result["hv_kv"] = float(m.group(1).replace(",", "."))

        # ── WD ───────────────────────────────────────────────────────────────
        m = _SEM_PATTERNS["wd"].search(flat)
        if m and "wd_mm" not in result:
            val  = float(m.group(1).replace(",", "."))
            unit = m.group(2).lower()
            result["wd_mm"] = val * 10 if unit == "cm" else val

    # ── Compute nm_per_px (priority: view_field > magnification) ─────────────
    nm_per_px = None
    source    = "none"

    if "view_field_value" in result:
        vf     = result["view_field_value"]
        unit   = result["view_field_unit"]
        factor = _UNIT_TO_NM.get(unit, 1.0)
        nm_per_px = (vf * factor) / w
        source = f"View field: {vf} {unit} / {w} px"

    elif "magnification" in result:
        # Typical SEM sensor width ≈ 130 µm; rough estimate only
        sensor_nm = 130_000
        nm_per_px = sensor_nm / (result["magnification"] * w)
        source = f"Magnification: {result['magnification']}× (estimated)"

    result["nm_per_px"]   = nm_per_px
    result["cal_source"]  = source
    log.info("SEM auto-detect: %s → %.4f nm/px", source,
             nm_per_px if nm_per_px else 0)
    return result

def detect_info_bar_row(img: np.ndarray, search_frac: float = 0.65) -> int:
    """
    Detect the pixel row where the SEM/TEM info bar begins.

    Uses horizontal Sobel edge energy — the info bar always starts with a
    sharp horizontal boundary line separating it from the micrograph content.

    Parameters
    ----------
    img          : BGR or grayscale image (numpy array)
    search_frac  : only search in the bottom (1-search_frac) fraction

    Returns
    -------
    int  row index of the bar boundary (exclusive — crop to img[:row])
         -1 if no clear bar detected (pure content, no overlay strip)
    """
    h, w = img.shape[:2]
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY) if img.ndim == 3 else img.copy()

    search_start = int(h * search_frac)
    region       = gray[search_start:, :]

    sobel_y    = cv2.Sobel(region.astype(np.float32), cv2.CV_32F, 0, 1, ksize=5)
    row_energy = np.sum(np.abs(sobel_y), axis=1)

    peak_local = int(np.argmax(row_energy))
    peak_val   = float(row_energy[peak_local])
    mean_energy = float(np.mean(row_energy))

    # Require peak to be significantly above average noise level
    if mean_energy < 1e-6 or peak_val < mean_energy * 2.5:
        return -1   # no bar found

    # Return 2 rows above the separator line to avoid including it
    bar_row = search_start + peak_local - 2
    log.info("Info bar detected at row %d / %d  (%.1f%%)", bar_row, h, bar_row/h*100)
    return max(bar_row, 0)

# ─── AI / AKILLI SEGMENTASYoN MODÜLü ────────────────────────────────────────
# CPU'da çalışan, internet gerektirmeyen akıllı segmentasyon sistemi.
#
# Bileşenler:
#   1. AutoThreshold   — histogram analizi ile en iyi yöntemi seçer
#   2. ImageQualityScorer — analiz öncesi görüntü kalitesini puanlar
#   3. SmartSegmentor  — 4 yöntemi çalıştırır, en iyisini önerir
#      a) Otsu (klasik)
#      b) Watershed   — birleşik bölgeleri ayırır (AI-like davranış)
#      c) Adaptive+CLAHE — düzensiz aydınlatmada
#      d) Multi-scale Ensemble — 3 sigma'da Otsu, en az 2/3 oyu al
# ---------------------------------------------------------------------------

from dataclasses import dataclass as _dc, field as _field
from typing import Tuple as _Tuple

@_dc
class QualityScore:
    sharpness:   int = 0   # 0-100
    contrast:    int = 0
    snr:         int = 0
    uniformity:  int = 0   # aydınlatma eşitliği
    overall:     int = 0
    snr_db:      float = 0.0
    vignette_ratio: float = 0.0
    recommended_method: str = "otsu"
    reason: str = ""

    def label(self) -> str:
        if self.overall >= 75: return "✓ Yüksek kalite"
        if self.overall >= 50: return "✓ Analiz edilebilir"
        return "⚠ Düşük kalite — sonuçları doğrulayın"

    def bar(self, v: int, width: int = 10) -> str:
        filled = round(v / 100 * width)
        return "█" * filled + "░" * (width - filled)


def score_image_quality(gray: np.ndarray) -> QualityScore:
    """
    Görüntü kalitesini 4 metrikte 0-100 arası puanlar ve
    en uygun eşikleme yöntemini önerir.
    """
    h, w = gray.shape

    # 1. Odak (Laplacian varyansı)
    lap_var   = float(cv2.Laplacian(gray, cv2.CV_64F).var())
    sharpness = min(100, int(lap_var / 5))

    # 2. Kontrast (normalize std)
    contrast_score = min(100, int(np.std(gray) / 128 * 100))

    # 3. SNR
    blurred   = cv2.GaussianBlur(gray, (5, 5), 0)
    noise     = float(np.std(gray.astype(float) - blurred.astype(float)))
    signal    = float(np.std(gray.astype(float)))
    snr_db    = 20 * np.log10(signal / max(noise, 1e-9))
    snr_score = min(100, int(snr_db * 3))

    # 4. Aydınlatma eşitliği (vinyeting)
    cy, cx     = h // 4, w // 4
    center     = gray[cy:h-cy, cx:w-cx]
    corners    = np.concatenate([
        gray[:h//6, :w//6].flatten(), gray[-h//6:, -w//6:].flatten(),
        gray[:h//6, -w//6:].flatten(), gray[-h//6:, :w//6].flatten(),
    ])
    vig_ratio  = abs(float(np.mean(center)) - float(np.mean(corners))) / 255.0
    vig_score  = max(0, int((1 - vig_ratio * 5) * 100))

    overall = int(sharpness * 0.30 + contrast_score * 0.25 +
                  snr_score * 0.25 + vig_score * 0.20)

    # ── Akıllı yöntem seçimi ──────────────────────────────────────────────
    # Bimodality coefficient (Sarle 1981)
    flat      = gray.flatten().astype(float)
    try:
        from scipy.stats import skew as _sk, kurtosis as _ku
        skewness  = float(_sk(flat))
        kurt_val  = float(_ku(flat))
    except ImportError:
        skewness, kurt_val = 0.0, 0.0
    bimodality = (skewness ** 2 + 1) / (kurt_val + 3 + 1e-9)

    if vig_ratio > 0.05:
        recommended = "adaptive"
        reason = (f"Düzensiz aydınlatma tespit edildi "
                  f"(merkez/köşe farkı: {vig_ratio*100:.1f}%)")
    elif bimodality > 0.555:
        recommended = "otsu"
        reason = (f"Bimodal histogram (BC={bimodality:.3f} > 0.555) "
                  f"— Otsu için ideal")
    else:
        recommended = "triangle"
        reason = (f"Unimodal histogram (BC={bimodality:.3f} ≤ 0.555) "
                  f"— seyrek yapılar için Triangle")

    return QualityScore(
        sharpness=sharpness, contrast=contrast_score,
        snr=snr_score, uniformity=vig_score, overall=overall,
        snr_db=round(snr_db, 1), vignette_ratio=round(vig_ratio, 3),
        recommended_method=recommended, reason=reason,
    )


def segment_watershed(gray: np.ndarray, min_pore_px: int = 8,
                       min_distance: int = 8) -> _Tuple[np.ndarray, np.ndarray]:
    """
    Otsu + Distance Transform + Watershed.
    Birleşik (aglomere) bölgeleri otomatik olarak ayırır.
    Returns: (labeled_image, binary_mask)
    """
    g_den  = cv2.fastNlMeansDenoising(gray, h=7,
                 templateWindowSize=7, searchWindowSize=21)
    _, mask = cv2.threshold(g_den, 0, 255,
                            cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    mask    = cv2.morphologyEx(mask, cv2.MORPH_OPEN,
                               np.ones((3, 3), np.uint8), iterations=2)
    dist    = ndimage.distance_transform_edt(mask)

    from skimage.feature import peak_local_max
    from skimage import segmentation as _seg

    coords  = peak_local_max(dist, min_distance=min_distance, labels=mask)
    markers = np.zeros(dist.shape, dtype=bool)
    if len(coords):
        markers[tuple(coords.T)] = True
    markers, _ = ndimage.label(markers)
    labels  = _seg.watershed(-dist, markers, mask=mask)
    return labels, mask


def segment_multiscale(gray: np.ndarray,
                       sigmas=(0.5, 1.0, 2.0),
                       min_votes: int = 2) -> np.ndarray:
    """
    Farklı Gaussian sigma değerlerinde Otsu uygular ve oylama yapar.
    En az `min_votes` yöntemde gözenek olarak işaretlenen pikseller tutulur.
    Returns: binary mask (uint8, 0/255)
    """
    votes = np.zeros(gray.shape, dtype=np.int32)
    for sigma in sigmas:
        blur = cv2.GaussianBlur(gray, (0, 0), sigma)
        _, m = cv2.threshold(blur, 0, 255,
                             cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
        votes += (m > 0).astype(np.int32)
    mask = ((votes >= min_votes).astype(np.uint8) * 255)
    return cv2.morphologyEx(mask, cv2.MORPH_OPEN,
                            np.ones((3, 3), np.uint8), iterations=2)


@_dc
class SegmentationResult:
    method:      str
    mask:        np.ndarray
    labels:      np.ndarray
    props:       list
    porosity_pct: float
    pore_count:  int
    diameters_px: np.ndarray
    quality_score: float = 0.0   # 0-1, internal ranking score


def smart_segment(gray: np.ndarray,
                  min_pore_px: int = 8,
                  cal: "ScaleCalibration" = None,
                  force_method: str = None) -> dict:
    """
    Görüntüyü 4 farklı yöntemle segmente eder.
    Her yönteme bir kalite skoru verir ve en iyisini işaretler.

    Parameters
    ----------
    gray         : gri ton görüntü (kırpılmış, bilgi çubuğu yok)
    min_pore_px  : minimum gözenek alanı (piksel)
    cal          : ScaleCalibration objesi (opsiyonel)
    force_method : None → otomatik seç  |  "otsu"/"adaptive"/"watershed"/"multiscale"

    Returns
    -------
    dict with keys:
        "recommended"  : str — önerilen yöntem adı
        "quality"      : QualityScore
        "methods"      : dict[str, SegmentationResult]
        "best"         : SegmentationResult
    """
    K3 = np.ones((3, 3), np.uint8)

    quality = score_image_quality(gray)
    if cal is not None:
        quality.recommended_method = (
            force_method or quality.recommended_method
        )
    recommended_method = force_method or quality.recommended_method

    clahe   = cv2.createCLAHE(clipLimit=2.5, tileGridSize=(8, 8))
    g_clahe = clahe.apply(gray)

    def _make_result(method, mask, labels=None):
        if labels is None:
            labeled = measure.label(mask)
        else:
            labeled = labels
        props = [p for p in measure.regionprops(labeled) if p.area >= min_pore_px]
        if labels is None:
            vm = np.zeros_like(mask)
            for p in props:
                vm[labeled == p.label] = 255
        else:
            vm = (labels > 0).astype(np.uint8) * 255
        areas = np.array([p.area for p in props]) if props else np.array([])
        diams = (2 * np.sqrt(areas / np.pi)) if len(areas) else np.array([])
        por   = round(float(np.sum(vm > 0)) / gray.size * 100, 3)
        # Quality ranking: reward moderate porosity (5-60%) and pore count
        q_score = 0.0
        if 5 <= por <= 60:
            q_score += 0.5
        if len(props) >= 10:
            q_score += 0.3 * min(1.0, len(props) / 100)
        if len(diams) > 1:
            cv_diams = float(np.std(diams)) / (float(np.mean(diams)) + 1e-9)
            q_score += 0.2 * (1 - min(1.0, cv_diams))
        return SegmentationResult(
            method=method, mask=vm, labels=labeled,
            props=props, porosity_pct=por, pore_count=len(props),
            diameters_px=diams, quality_score=round(q_score, 3),
        )

    results = {}

    # A — Otsu
    _, m_otsu = cv2.threshold(gray, 0, 255,
                              cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    m_otsu = cv2.morphologyEx(m_otsu, cv2.MORPH_OPEN, K3, iterations=2)
    results["otsu"] = _make_result("otsu", m_otsu)

    # B — Watershed
    lab_ws, _ = segment_watershed(gray, min_pore_px, min_distance=8)
    results["watershed"] = _make_result("watershed", None, labels=lab_ws)

    # C — Adaptive + CLAHE
    m_adp = cv2.adaptiveThreshold(g_clahe, 255,
                cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
                cv2.THRESH_BINARY_INV, 31, 5)
    m_adp = cv2.morphologyEx(m_adp, cv2.MORPH_OPEN, K3, iterations=2)
    results["adaptive"] = _make_result("adaptive", m_adp)

    # D — Multi-scale Ensemble
    m_ms = segment_multiscale(gray)
    results["multiscale"] = _make_result("multiscale", m_ms)

    # Pick best — honour recommendation if quality score is reasonable
    rec = results.get(recommended_method)
    if rec and rec.quality_score >= 0.3:
        best_key = recommended_method
    else:
        best_key = max(results, key=lambda k: results[k].quality_score)

    log.info("SmartSegment: recommended=%s  best=%s  quality=%d/100",
             recommended_method, best_key, quality.overall)

    return {
        "recommended": best_key,
        "quality":     quality,
        "methods":     results,
        "best":        results[best_key],
    }





def load_recent() -> List[str]:
    try:
        if RECENT_FILE.exists():
            data = json.loads(RECENT_FILE.read_text(encoding="utf-8"))
            return [p for p in data.get("files", []) if Path(p).exists()]
    except Exception:
        pass
    return []


def save_recent(files: List[str]):
    try:
        RECENT_FILE.write_text(
            json.dumps({"files": files[:MAX_RECENT]}, indent=2),
            encoding="utf-8",
        )
    except Exception:
        pass


def add_recent(path: str, files: List[str]) -> List[str]:
    files = [f for f in files if f != path]
    files.insert(0, path)
    return files[:MAX_RECENT]


