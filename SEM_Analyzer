    # ── RUN ───────────────────────────────────────────────────────────────────
    def _run(self):
        path = self.img_path.get().strip()
        mode = self.mode_var.get()
        if not path and mode != "Comparison":
            messagebox.showwarning(self.t("dlg_no_img"), self.t("dlg_no_img_msg"))
            return
        if mode == "Comparison" and (not self.img_path.get() or not self.img_path2.get()):
            messagebox.showwarning(self.t("dlg_two_img"), self.t("dlg_two_img_msg"))
            return
        # Sync smart scale calibration — image_width_px is already set by load_image
        try:
            val = float(self.scale_val_var.get().replace(",", "."))
        except (ValueError, AttributeError):
            val = 0.0
        unit = self.scale_unit_var.get() or "nm"
        self.engine.calibration.scale_value = val
        self.engine.calibration.scale_unit  = unit
        # image_width_px was synced at load time; re-apply in case user
        # typed a value before loading (engine may hold stale 1)
        if self.engine.meta.width > 0:
            self.engine.calibration.image_width_px = self.engine.meta.width

        self._clear_dirty()
        self.progress.start(8)
        self._set_status(self.t("status_analyzing"), C["amber"])
        threading.Thread(target=self._thread, daemon=True).start()

    def _thread(self):
        try:
            mode = self.mode_var.get()
            path = self.img_path.get().strip()
            if mode != "Comparison":
                self.engine.load_image(path)
            if mode == "Porosity":
                r = self.engine.analyze_porosity(self.thresh_var.get(), self.min_pore_var.get())
                self.after(0, lambda: self._disp_porosity(r))
            elif mode == "Fouling Layer":
                r = self.engine.analyze_fouling(self.side_var.get())
                self.after(0, lambda: self._disp_fouling(r))
            elif mode == "Active Sites":
                r = self.engine.analyze_active_sites(self.cluster_var.get())
                self.after(0, lambda: self._disp_sites(r))
            elif mode == "Comparison":
                r = self.engine.compare_images(self.img_path.get(),
                                               self.img_path2.get(),
                                               self.thresh_var.get())
                self.after(0, lambda: self._disp_comparison(r))
            ts  = datetime.datetime.now().strftime("%H:%M:%S")
            msg = f"[{ts}] {mode}" + self.t("log_done")
            self.after(0, lambda: self._log_add(msg, "ok"))
            self.after(0, lambda: self._set_status(self.t("status_done"), C["teal"]))
        except Exception as e:
            err = str(e)
            log.error("Analysis error: %s", err)
            self.after(0, lambda: self._log_add(self.t("log_err") + err, "err"))
            self.after(0, lambda: messagebox.showerror(self.t("dlg_err"), err))
            self.after(0, lambda: self._set_status(self.t("status_error"), C["red"]))
        finally:
            self.after(0, self.progress.stop)

    # ── RESULTS TEXT ──────────────────────────────────────────────────────────
    def _rt_default(self):
        self.rt.configure(state="normal")
        self.rt.delete("1.0", "end")
        self.rt.insert("end", self.t("rt_default1"), "key")
        self.rt.insert("end", self.t("rt_default2"), "key")
        self.rt.configure(state="disabled")

    def _clr_rt(self):
        self.rt.configure(state="normal")
        self.rt.delete("1.0", "end")

    def _rt_head(self, key: str):
        self.rt.insert("end", f"\n  {self.t(key)}\n  {'─'*46}\n", "hdr")

    def _rt_row(self, key: str, val, tag: str = "ok"):
        self.rt.insert("end", f"  {self.t(key):<36}", "key")
        self.rt.insert("end", f"{val}\n", tag)

    # ── DISPLAY ───────────────────────────────────────────────────────────────
    def _disp_porosity(self, r: PorosityResult):
        cal = self.engine.calibration

        def _fmt(px_val: float) -> str:
            """Format a pixel length with physical unit if calibrated."""
            if cal.is_calibrated:
                return f"{px_val:.2f} px  =  {cal.format_length(px_val)}"
            return f"{px_val:.2f} px"

        self._clr_rt()

        # ── Kalite skoru + akıllı öneri ───────────────────────────────────
        q = getattr(self.engine.por_analyzer, "last_quality", None)
        if q:
            self.rt.configure(state="normal")
            self.rt.insert("end", f"\n  GÖRÜNTÜ KALİTE SKORU\n  {'─'*46}\n", "hdr")
            def _bar(v): return "█"*(v//10) + "░"*(10-v//10)
            for lbl, val, unit in [
                ("Odak (sharpness)", q.sharpness, "%"),
                ("Kontrast",         q.contrast,  "%"),
                ("SNR",              q.snr,       f"%  ({q.snr_db} dB)"),
                ("Aydınlatma eşitliği", q.uniformity, "%"),
                ("Genel",            q.overall,   f"/100  {q.label()}"),
            ]:
                tag = "ok" if val >= 60 else "warn"
                self.rt.insert("end", f"  {lbl:<28}", "key")
                self.rt.insert("end", f"{_bar(val)}  {val}{unit}\n", tag)
            self.rt.insert("end", f"\n  ⚡ Önerilen yöntem: {q.recommended_method.upper()}\n", "info")
            self.rt.insert("end", f"     {q.reason}\n\n", "key")

        self._rt_head("hdr_por")
        self._rt_row("k_method",     r["method"].upper(), "info")
        self._rt_row("k_porosity",   f"{r['porosity_pct']:.3f} %",
                     "warn" if r["porosity_pct"] < 5 else "ok")
        self._rt_row("k_pore_count", r["pore_count"])

        if cal.is_calibrated:
            # Show calibration summary inline
            lbl_scale = "Ölçek:" if self._lang == "TR" else "Scale:"
            cal_line  = f"  {lbl_scale:<36}{cal.summary()}"
            self.rt.insert("end", cal_line + "\n", "info")


        self._rt_head("hdr_psd")
        self._rt_row("k_mean_diam",   _fmt(r["mean_diam_px"]))
        self._rt_row("k_std_diam",    f"{r['std_diam_px']:.2f} px")
        self._rt_row("k_min_diam",    _fmt(r["min_diam_px"]))
        self._rt_row("k_max_diam",    _fmt(r["max_diam_px"]))
        self._rt_head("hdr_psd_pct")
        self._rt_row("k_d10",         _fmt(r["d10_px"]))
        self._rt_row("k_d50",         _fmt(r["d50_px"]))
        self._rt_row("k_d90",         _fmt(r["d90_px"]))
        self._rt_row("k_eccentric",   r["mean_eccentric"])
        self.rt.configure(state="disabled")

        self.mc["porosity"].set(f"{r['porosity_pct']:.2f}")
        self.mc["pores"].set(r["pore_count"])
        self.mc["diam"].set(f"{r['mean_diam_px']:.1f}")
        self.mc["fouling"].set("--")

        ov = self.engine.original.copy()
        ov[r["mask"] > 0] = [0, 175, 140]
        self._show_cv2(cv2.addWeighted(self.engine.original, 0.55, ov, 0.45, 0))
        self._plt_porosity(r)

    def _disp_fouling(self, r: FoulingResult):
        self._clr_rt()
        self._rt_head("hdr_foul")
        self._rt_row("k_side",      r["layer_side"].upper(), "info")
        self._rt_row("k_interface", r["interface_row_px"])
        cal = self.engine.calibration
        thick_px  = r["fouling_thickness_px"]
        thick_fmt = f"{thick_px} px"
        if cal.is_calibrated:
            thick_fmt += f"  =  {cal.format_length(thick_px)}"
        self._rt_row("k_f_px",  thick_fmt)
        self._rt_row("k_f_pct", f"{r['fouling_thickness_pct']:.2f} %",
                     "warn" if r["fouling_thickness_pct"] > 30 else "ok")
        self._rt_head("hdr_int")
        self._rt_row("k_l_int",    r["layer_mean_intensity"])
        self._rt_row("k_m_int",    r["membrane_mean_intensity"])
        self._rt_row("k_contrast", r["contrast_ratio"])
        self._rt_row("k_snr",      f"{r['snr_db']:.2f} dB",
                     "ok" if r["snr_db"] > 10 else "warn")
        self.rt.configure(state="disabled")

        self.mc["fouling"].set(r["fouling_thickness_px"])
        for k in ["porosity", "pores", "diam"]:
            self.mc[k].set("--")
        self._plt_fouling(r)

    def _disp_sites(self, r: ActiveSiteResult):
        self._clr_rt()
        self._rt_head("hdr_sites")
        self._rt_row("k_k",          r["cluster_count"], "info")
        self._rt_row("k_bright_cnt", r["bright_site_count"])
        self._rt_row("k_dark_cnt",   r["dark_site_count"])
        self._rt_row("k_total_cnt",  r["total_site_count"])
        self._rt_head("hdr_cov")
        self._rt_row("k_bright_cov", f"{r['bright_coverage_pct']:.3f} %")
        self._rt_row("k_dark_cov",   f"{r['dark_coverage_pct']:.3f} %")
        self._rt_row("k_total_cov",  f"{r['total_coverage_pct']:.3f} %",
                     "warn" if r["total_coverage_pct"] < 1.0 else "ok")
        self.rt.configure(state="disabled")

        self.mc["pores"].set(r["total_site_count"])
        for k in ["porosity", "diam", "fouling"]:
            self.mc[k].set("--")
        self._plt_sites(r)

    def _disp_comparison(self, r: ComparisonResult):
        self._clr_rt()
        self._rt_head("hdr_comp")
        self._rt_row("k_img1_por", f"{r['img1_porosity']:.3f}")
        self._rt_row("k_img2_por", f"{r['img2_porosity']:.3f}")
        d = r["delta_porosity"]
        self._rt_row("k_delta",    f"{d:+.3f} %", "warn" if abs(d) > 5 else "ok")
        self._rt_head("hdr_cnt")
        self._rt_row("k_img1_cnt",  r["img1_pore_count"])
        self._rt_row("k_img2_cnt",  r["img2_pore_count"])
        self._rt_row("k_img1_diam", r["img1_mean_diam"])
        self._rt_row("k_img2_diam", r["img2_mean_diam"])
        self.rt.configure(state="disabled")

        self.mc["porosity"].set(f"{d:+.2f}")
        self.mc["pores"].set(f"{r['img1_pore_count']} / {r['img2_pore_count']}")
        self.mc["diam"].set(f"{r['img1_mean_diam']:.1f}")
        self.mc["fouling"].set("--")
        self._plt_comparison(r)

    # ── CHARTS ────────────────────────────────────────────────────────────────
    def _ax_style(self, ax):
        ax.set_facecolor(C["bg_card"])
        ax.tick_params(colors=C["text_lo"], labelsize=7)
        for sp in ax.spines.values():
            sp.set_edgecolor(C["border"])

    def _clr_fig(self):
        self.fig.clf()
        self.fig.patch.set_facecolor(C["bg_card"])

    def _plt_porosity(self, r: PorosityResult):
        self._clr_fig()
        ax1 = self.fig.add_subplot(1, 3, 1)
        ax2 = self.fig.add_subplot(1, 3, 2)
        ax3 = self.fig.add_subplot(1, 3, 3)

        ax1.imshow(r["mask"], cmap="Greens")
        ax1.set_title(self.t("ct_mask"), color=C["teal"], fontsize=9, pad=5)
        ax1.axis("off")

        if len(r["diameters"]) > 0:
            cal = self.engine.calibration
            # Convert diameters to physical units if calibrated
            if cal.is_calibrated:
                nm_px = cal.nm_per_px
                diams_phys = r["diameters"] * nm_px
                d10_p  = r["d10_px"] * nm_px
                d50_p  = r["d50_px"] * nm_px
                d90_p  = r["d90_px"] * nm_px
                # choose best display unit
                med = float(np.median(diams_phys))
                if med >= 1_000_000:
                    diams_plot = diams_phys / 1_000_000
                    d10_p /= 1_000_000; d50_p /= 1_000_000; d90_p /= 1_000_000
                    x_label = "Diameter (mm)"
                elif med >= 1_000:
                    diams_plot = diams_phys / 1_000
                    d10_p /= 1_000; d50_p /= 1_000; d90_p /= 1_000
                    x_label = "Diameter (µm)"
                else:
                    diams_plot = diams_phys
                    x_label = "Diameter (nm)"
            else:
                diams_plot = r["diameters"]
                d10_p, d50_p, d90_p = r["d10_px"], r["d50_px"], r["d90_px"]
                x_label = self.t("ax_diam")

            ax2.hist(diams_plot, bins=30, color=C["teal"],
                     alpha=0.8, edgecolor=C["teal_dim"], linewidth=0.5)
            for p_val, p_name, p_col in [
                (d10_p, "D10", C["blue"]),
                (d50_p, "D50", C["amber"]),
                (d90_p, "D90", C["red"]),
            ]:
                ax2.axvline(p_val, color=p_col, lw=1.2, ls="--",
                            label=f"{p_name}={p_val:.2f}")
            ax2.set_xlabel(x_label,            color=C["text_lo"], fontsize=8)
            ax2.set_ylabel(self.t("ax_count"), color=C["text_lo"], fontsize=8)
            ax2.set_title(self.t("ct_psd"),    color=C["teal"],    fontsize=9, pad=5)
            ax2.legend(fontsize=6, facecolor=C["bg_card"],
                       labelcolor=C["text_md"], framealpha=0.8)

        # Eccentricity distribution
        if r["props"]:
            eccs = [p.eccentricity for p in r["props"]]
            ax3.hist(eccs, bins=20, color=C["blue"], alpha=0.8,
                     edgecolor=C["blue_dim"], linewidth=0.5)
            ax3.set_xlabel("Eccentricity", color=C["text_lo"], fontsize=8)
            ax3.set_ylabel(self.t("ax_count"), color=C["text_lo"], fontsize=8)
            ax3.set_title("Eccentricity Distribution", color=C["blue"], fontsize=9, pad=5)

        for ax in (ax1, ax2, ax3):
            self._ax_style(ax)
        self.fig.tight_layout(pad=1.5)
        self.plot_cv.draw()
        self.nb.select(self.tab_c)

