class MembraneAnalyzerApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self._lang   = "TR"
        self.engine  = AnalysisEngine()
        self.img_path  = tk.StringVar()
        self.img_path2 = tk.StringVar()
        self._recent: List[str] = load_recent()
        self._params_dirty = False   # re-run reminder flag

        self._dyn:         Dict[int, tuple] = {}
        self._mode_labels: Dict[str, tk.Label]  = {}
        self._mode_inds:   Dict[str, tk.Frame]  = {}

        self.title(f"Membrane Science Analyzer  |  SEM/TEM  v{APP_VERSION}")
        self.geometry("1520x940")
        self.minsize(1100, 720)
        self.configure(bg=C["bg_root"])
        self.resizable(True, True)

        self._build()
        self._apply_ttk()
        self._bind_shortcuts()
        self._bind_dnd()

        self.after(50, lambda: self.mode_var.set(self.mode_var.get()))

    # ── i18n ──────────────────────────────────────────────────────────────────
    def t(self, key: str) -> str:
        return LANG[self._lang].get(key, key)

    def _i18n_reg(self, widget, attr: str, lang_key: str):
        self._dyn[id(widget)] = (widget, attr, lang_key)

    def _apply_lang(self):
        for _, (widget, attr, key) in self._dyn.items():
            try:
                widget.configure(**{attr: self.t(key)})
            except Exception:
                pass
        mode_key_map = {
            "Porosity":     "mode_por",
            "Fouling Layer":"mode_foul",
            "Active Sites": "mode_sites",
            "Comparison":   "mode_comp",
        }
        for val, lbl_w in self._mode_labels.items():
            lbl_w.configure(text=self.t(mode_key_map[val]))
        for k, (mc, lk, uk) in self._mc_meta.items():
            mc.relabel(self.t(lk), self.t(uk))
        self.nb.tab(self.tab_r, text=self.t("tab_results"))
        self.nb.tab(self.tab_c, text=self.t("tab_charts"))
        self.nb.tab(self.tab_l, text=self.t("tab_log"))
        self._sub_lbl.configure(text=self.t("app_sub"))
        self._status_lbl.configure(text=" " + self.t("status_ready"))
        self._zoom_hint.configure(text=self.t("zoom_hint"))
        self._rt_default()
        self._rebuild_recent_menu()
        if not self.img_path.get():
            self._placeholder()

    def _toggle_lang(self):
        self._lang = "EN" if self._lang == "TR" else "TR"
        self._lang_btn.configure(text=self.t("lang_btn"))
        self._apply_lang()

    # ─── KEYBOARD SHORTCUTS ───────────────────────────────────────────────────
    def _bind_shortcuts(self):
        self.bind("<Control-o>",         lambda e: self._browse1())
        self.bind("<F5>",                lambda e: self._run())
        self.bind("<Control-s>",         lambda e: self._export_csv())
        self.bind("<Control-S>",         lambda e: self._export_pdf())
        self.bind("<Control-z>",         lambda e: self._reset())
        self.bind("<Control-r>",         lambda e: self._run())

    # ─── DRAG & DROP ──────────────────────────────────────────────────────────
    def _bind_dnd(self):
        """Best-effort drag & drop via tkinterdnd2 or Tkinter internals."""
        try:
            from tkinterdnd2 import DND_FILES
            self.img_canvas.drop_target_register(DND_FILES)
            self.img_canvas.dnd_bind("<<Drop>>", self._on_drop)
        except Exception:
            # Fallback: Windows shell drop target via Tkinter
            try:
                self.img_canvas.bind("<Drop>", self._on_drop)
            except Exception:
                pass

    def _on_drop(self, event):
        raw = getattr(event, "data", None) or str(event)
        path = raw.strip().strip("{}")
        if path:
            self._load_file(path)

    # ─── BUILD ────────────────────────────────────────────────────────────────
    def _build(self):
        self._build_menu()
        self._build_topbar()
        body = tk.Frame(self, bg=C["bg_root"])
        body.pack(fill="both", expand=True)
        self._build_sidebar(body)
        self._build_main(body)

    # ── MENU ──────────────────────────────────────────────────────────────────
    def _build_menu(self):
