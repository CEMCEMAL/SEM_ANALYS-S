@dataclass
class ImageMeta:
    path: str       = ""
    width: int      = 0
    height: int     = 0
    channels: int   = 1
    bit_depth: int  = 8
    file_size_kb: float = 0.0

    def label(self) -> str:
        sz = f"{self.file_size_kb:.1f} KB" if self.file_size_kb < 1024 else f"{self.file_size_kb/1024:.2f} MB"
        return (f"  {Path(self.path).name}  ·  "
                f"{self.width}×{self.height}  ·  "
                f"{self.channels}ch  ·  {self.bit_depth}bit  ·  {sz}")


@dataclass
class ScaleCalibration:
    """
    Smart scale calibration.

    The user enters ONE value — the physical width the entire image represents
    — plus the unit (nm, µm, mm).  The system derives nm_per_px automatically
    from the image width in pixels.

    Example:
        image_width_px = 1024
        scale_value    = 500   (user typed "500")
        scale_unit     = "nm"
        → nm_per_px    = 500 / 1024  ≈ 0.488 nm/px
        → um_per_px    = 0.488 / 1000
    """
    scale_value: float = 0.0      # physical span the image covers (in chosen unit)
    scale_unit:  str   = "nm"     # "nm" | "µm" | "mm"
    image_width_px: int = 1       # set automatically when image is loaded

    # ── derived ──────────────────────────────────────────────────────────────
    @property
    def is_calibrated(self) -> bool:
        return self.scale_value > 0 and self.image_width_px > 0

    @property
    def nm_per_px(self) -> float:
        """Nanometres per pixel — the universal internal unit."""
        if not self.is_calibrated:
            return 0.0
        factor = {"nm": 1.0, "µm": 1_000.0, "mm": 1_000_000.0}.get(self.scale_unit, 1.0)
        return (self.scale_value * factor) / self.image_width_px

    @property
    def um_per_px(self) -> float:
        return self.nm_per_px / 1_000.0

    def px_to_nm(self, px: float) -> float:
        return px * self.nm_per_px

    def px_to_um(self, px: float) -> float:
        return px * self.um_per_px

    def format_length(self, px: float, decimals: int = 3) -> str:
        """Return the best human-readable string for a pixel length."""
        if not self.is_calibrated:
            return f"{px:.2f} px"
        nm = self.px_to_nm(px)
        if nm >= 1_000_000:
            return f"{nm/1_000_000:.{decimals}f} mm"
        if nm >= 1_000:
            return f"{nm/1_000:.{decimals}f} µm"
        return f"{nm:.{decimals}f} nm"

    def summary(self) -> str:
        if not self.is_calibrated:
            return "Kalibrasyon yok — sonuçlar px cinsinden"
        return (f"{self.scale_value} {self.scale_unit} / görüntü  "
                f"·  {self.nm_per_px:.4f} nm/px  "
                f"·  {self.um_per_px:.6f} µm/px")


