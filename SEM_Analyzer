    def _auto_detect_scale(self, path: str):
        """
        Called after image load. Runs SEM metadata OCR in a background
        thread and populates the scale fields if successful.
        """
        def _worker():
            meta = extract_sem_metadata(path)
            nm   = meta.get("nm_per_px")
            vf_v = meta.get("view_field_value")
            vf_u = meta.get("view_field_unit", "µm")
            src  = meta.get("cal_source", "")
            mag  = meta.get("magnification")
            hv   = meta.get("hv_kv")
            wd   = meta.get("wd_mm")

            if nm and nm > 0:
                self.after(0, lambda: self._apply_auto_scale(vf_v, vf_u, nm, src, meta))
            else:
                log.info("Auto-detect: no scale found in %s", path)

        threading.Thread(target=_worker, daemon=True).start()

    def _apply_auto_scale(self, vf_v, vf_u, nm_per_px, source, meta):
        """Apply auto-detected scale to the UI — runs on main thread."""
        # Populate the scale entry fields
        if vf_v is not None:
            self.scale_val_var.set(str(vf_v))
            self.scale_unit_var.set(vf_u)
        else:
            # No view field but we have nm_per_px from magnification
            # Show in nm with image width
            w  = self.engine.meta.width or 1
            nm_total = nm_per_px * w
            self.scale_val_var.set(f"{nm_total:.1f}")
            self.scale_unit_var.set("nm")

        # Sync engine calibration immediately
        self.engine.calibration.scale_value    = float(self.scale_val_var.get())
        self.engine.calibration.scale_unit     = self.scale_unit_var.get()
        self.engine.calibration.image_width_px = self.engine.meta.width

        # Build a rich info string with all detected metadata
        parts = []
        if meta.get("magnification"):
            parts.append(f"Büyütme: {meta['magnification']:.0f}×" if self._lang == "TR"
                         else f"Mag: {meta['magnification']:.0f}×")
        if meta.get("hv_kv"):
            parts.append(f"HV: {meta['hv_kv']} kV")
        if meta.get("wd_mm"):
            parts.append(f"WD: {meta['wd_mm']} mm")

        extra = "   ·   ".join(parts)
        lbl_auto = "Ölçek otomatik algılandı" if self._lang == "TR" else "Scale auto-detected"
        phys_str = f"{source}  →  {nm_per_px:.4f} nm/px"
        log_msg  = lbl_auto + ": " + phys_str
        if extra:
            log_msg += "\n" + extra

        self._log_add(log_msg, "ok")
        self._on_scale_change()

        # Flash the scale info label briefly in teal to signal auto-fill
        self._scale_info_lbl.configure(fg=C["teal"])
        self.after(2500, lambda: self._scale_info_lbl.configure(fg=C["teal"]))

    def _on_scale_change(self, *_):
        """Live update: recalculate nm/px as user types and show derived info."""
        try:
            val  = float(self.scale_val_var.get().replace(",", "."))
        except (ValueError, AttributeError):
            self._scale_info_lbl.configure(text="")
            return

        unit = self.scale_unit_var.get() or "nm"
        w    = self.engine.meta.width if self.engine.meta.width > 0 else 1

        # Build a temporary calibration to compute values
        tmp = ScaleCalibration(scale_value=val, scale_unit=unit, image_width_px=w)

        if not tmp.is_calibrated:
            self._scale_info_lbl.configure(text="")
            return

        nm_px = tmp.nm_per_px
        um_px = tmp.um_per_px

        # Auto-pick best display unit for the per-pixel value
        if nm_px >= 1000:
            px_str = f"{um_px:.4f} µm/px"
        else:
            px_str = f"{nm_px:.4f} nm/px"

        # Show what the full image spans
        factor = {"nm": 1.0, "µm": 1_000.0, "mm": 1_000_000.0}.get(unit, 1.0)
        total_nm = val * factor
        if total_nm >= 1_000_000:
            total_str = f"{total_nm/1_000_000:.3f} mm"
        elif total_nm >= 1_000:
            total_str = f"{total_nm/1_000:.3f} µm"
        else:
            total_str = f"{total_nm:.1f} nm"

        if w > 1:
            info = f"→ {px_str}   (görüntü: {total_str} / {w} px)"
        else:
            info = f"→ {px_str}   (görüntü henüz yüklenmedi)"

        self._scale_info_lbl.configure(text=info)
        log.info("Scale preview: %s", info)

