class BaseAnalyzer:
    """Shared image loading & validation."""

    def __init__(self):
        self.original: Optional[np.ndarray] = None
        self.gray:     Optional[np.ndarray] = None
        self.meta:     ImageMeta            = ImageMeta()

    def load_image(self, path: str) -> np.ndarray:
        if not Path(path).exists():
            raise FileNotFoundError(f"File not found: {path}")
        img = cv2.imread(path, cv2.IMREAD_UNCHANGED)
        if img is None:
            try:
                pil = Image.open(path).convert("RGB")
                img = cv2.cvtColor(np.array(pil), cv2.COLOR_RGB2BGR)
            except Exception as e:
                raise ValueError(f"Cannot load image: {path}\n{e}")
        # Normalise to 8-bit BGR
        if img.dtype == np.uint16:
            img = (img / 256).astype(np.uint8)
        if img.ndim == 2:
            img = cv2.cvtColor(img, cv2.COLOR_GRAY2BGR)
        if img.shape[2] == 4:
            img = cv2.cvtColor(img, cv2.COLOR_BGRA2BGR)

        h, w = img.shape[:2]
        if h < 32 or w < 32:
            raise ValueError(f"Image too small ({w}×{h} px). Minimum: 32×32.")

        # ── Auto-crop SEM/TEM info bar ─────────────────────────────────────
        bar_row = detect_info_bar_row(img)
        if bar_row > 0 and bar_row < h:
            img  = img[:bar_row, :]
            h, w = img.shape[:2]
            log.info("Info bar cropped → analysis region: %dx%d", w, h)
        # ──────────────────────────────────────────────────────────────────

        self.original = img
        self.gray     = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

        file_kb = Path(path).stat().st_size / 1024
        self.meta = ImageMeta(
            path=path, width=w, height=h,
            channels=img.shape[2], bit_depth=8,
            file_size_kb=file_kb,
        )
        log.info("Loaded image: %s  (%dx%d)", Path(path).name, w, h)
        return img


class PorosityAnalyzer(BaseAnalyzer):
    """Pore detection & morphometric analysis."""

    def analyze(
        self,
        method: str = "auto",   # "auto" → SmartSegmentor seçer
        min_pore_px: int = 10,
        cal: "ScaleCalibration" = None,
    ) -> PorosityResult:
        if self.gray is None:
            raise RuntimeError("No image loaded.")
        if min_pore_px < 1:
            raise ValueError("Min pore size must be ≥ 1 px.")
        if cal is None:
            cal = ScaleCalibration()

        g = self.gray.copy()

        # ── AI / Akıllı Segmentasyon ───────────────────────────────────────
        force = None if method == "auto" else (
            method if method in ("otsu","adaptive","watershed","multiscale") else None
        )
        seg = smart_segment(g, min_pore_px=min_pore_px, cal=cal, force_method=force)
        self.last_quality = seg["quality"]
        self.last_seg     = seg

        # Triangle hâlâ destekleniyor (akıllı seçim dışında)
        if method == "triangle":
            _, mask_t = cv2.threshold(g, 0, 255,
                                      cv2.THRESH_BINARY_INV + cv2.THRESH_TRIANGLE)
            mask_t = cv2.morphologyEx(mask_t, cv2.MORPH_OPEN,
                                      np.ones((3,3),np.uint8), iterations=2)
            labeled_t = measure.label(mask_t)
            props_t   = [p for p in measure.regionprops(labeled_t) if p.area >= min_pore_px]
            valid_mask = np.zeros_like(mask_t)
            for p in props_t:
                valid_mask[labeled_t == p.label] = 255
            props = props_t
        else:
            best       = seg["best"]
            valid_mask = best.mask
            props      = best.props
            method     = best.method   # gerçekte kullanılan yöntemi kaydet

        areas     = np.array([p.area        for p in props]) if props else np.array([])
        diameters = (2 * np.sqrt(areas / np.pi)) if len(areas) else np.array([])
        eccs      = np.array([p.eccentricity for p in props]) if props else np.array([])
        thresh    = None

        def _pct(arr, q):
            return round(float(np.percentile(arr, q)) if len(arr) else 0, 2)

        mean_d_px  = round(float(np.mean(diameters)) if len(diameters) else 0, 2)
        min_d_px   = round(float(np.min(diameters))  if len(diameters) else 0, 2)
        max_d_px   = round(float(np.max(diameters))  if len(diameters) else 0, 2)
        d10_px     = _pct(diameters, 10)
        d50_px     = _pct(diameters, 50)
        d90_px     = _pct(diameters, 90)

        # Physical unit conversion — fully automatic from ScaleCalibration
        nm_per_px  = cal.nm_per_px if cal.is_calibrated else 0.0

        result: PorosityResult = {
            "method":         method,
            "threshold":      thresh if thresh is not None else "adaptive",
            "porosity_pct":   round(int(np.sum(valid_mask > 0)) / g.size * 100, 3),
            "pore_count":     len(props),
            "mean_diam_px":   mean_d_px,
            "std_diam_px":    round(float(np.std(diameters)) if len(diameters) else 0, 2),
            "min_diam_px":    min_d_px,
            "max_diam_px":    max_d_px,
            "d10_px":         d10_px,
            "d50_px":         d50_px,
            "d90_px":         d90_px,
            "mean_eccentric": round(float(np.mean(eccs)) if len(eccs) else 0, 3),
            # physical dimensions (0.0 when not calibrated)
            "nm_per_px":      round(nm_per_px, 6),
            "mean_diam_nm":   round(mean_d_px * nm_per_px, 3),
            "mean_diam_um":   round(mean_d_px * nm_per_px / 1000, 6),
            "d10_nm":         round(d10_px     * nm_per_px, 3),
            "d50_nm":         round(d50_px     * nm_per_px, 3),
            "d90_nm":         round(d90_px     * nm_per_px, 3),
            "min_diam_nm":    round(min_d_px   * nm_per_px, 3),
            "max_diam_nm":    round(max_d_px   * nm_per_px, 3),
            "mask":           valid_mask,
            "props":          props,
            "areas":          areas,
            "diameters":      diameters,
        }
        log.info("Porosity: %.3f %% | %d pores | nm/px=%.4f",
                 result["porosity_pct"], result["pore_count"], nm_per_px)
        return result


class FoulingAnalyzer(BaseAnalyzer):
    """Fouling layer thickness & intensity analysis."""

    def analyze(self, layer_side: str = "top") -> FoulingResult:
        if self.gray is None:
            raise RuntimeError("No image loaded.")

        valid_sides = ("top", "bottom", "left", "right")
        if layer_side not in valid_sides:
            raise ValueError(f"layer_side must be one of {valid_sides}, got '{layer_side}'")

        g    = self.gray.copy()
        h, w = g.shape

        if layer_side in ("top", "bottom"):
            profile, dim = np.mean(g, axis=1), h
        else:
            profile, dim = np.mean(g, axis=0), w

        sobelx      = cv2.Sobel(g, cv2.CV_64F, 1, 0, ksize=5)
        sobely      = cv2.Sobel(g, cv2.CV_64F, 0, 1, ksize=5)
        edge_map    = np.sqrt(sobelx**2 + sobely**2)
        canny_edges = canny(g.astype(float) / 255.0, sigma=2.0)

        smooth_grad = ndimage.gaussian_filter1d(np.abs(np.gradient(profile)), sigma=5)
        half        = dim // 2

        if layer_side in ("top", "left"):
            idx   = int(np.argmax(smooth_grad[:half]))
            thick = idx
        else:  # bottom, right
            idx   = dim - int(np.argmax(smooth_grad[half:][::-1])) - 1
            thick = dim - idx

        if layer_side == "top":
            lr, mr = g[:idx, :], g[idx:, :]
        elif layer_side == "bottom":
            lr, mr = g[idx:, :], g[:idx, :]
        elif layer_side == "left":
            lr, mr = g[:, :idx], g[:, idx:]
        else:
            lr, mr = g[:, idx:], g[:, :idx]

        l_mean = float(np.mean(lr)) if lr.size else 0.0
        m_mean = float(np.mean(mr)) if mr.size else 0.0
        noise  = float(np.std(lr))  if lr.size else 1e-9
        # SNR = signal difference / noise (dB)
        snr_db = round(20 * np.log10(abs(m_mean - l_mean) / max(noise, 1e-9) + 1e-9), 2)

        result: FoulingResult = {
            "layer_side":              layer_side,
            "interface_row_px":        idx,
            "fouling_thickness_px":    thick,
            "fouling_thickness_pct":   round(thick / dim * 100, 2),
            "layer_mean_intensity":    round(l_mean, 2),
            "membrane_mean_intensity": round(m_mean, 2),
            "contrast_ratio":          round(float(np.std(g)), 3),
            "snr_db":                  snr_db,
            "profile":                 profile,
            "smooth_grad":             smooth_grad,
            "edge_map":                edge_map,
            "canny_edges":             canny_edges,
        }
        log.info("Fouling: side=%s | thick=%d px (%.1f%%) | SNR=%.1f dB",
                 layer_side, thick, result["fouling_thickness_pct"], snr_db)
        return result


class ActiveSiteAnalyzer(BaseAnalyzer):
    """Active site / catalyst region detection using K-Means + percentile thresholding."""

    def analyze(self, cluster_count: int = 5, min_area: int = 5) -> ActiveSiteResult:
        if self.gray is None:
            raise RuntimeError("No image loaded.")
        if not (2 <= cluster_count <= 12):
            raise ValueError("cluster_count must be between 2 and 12.")

        g  = self.gray.copy()
        g8 = (exposure.equalize_adapthist(g, clip_limit=0.03) * 255).astype(np.uint8)

        bm = (g8 >= int(np.percentile(g8, 90))).astype(np.uint8) * 255
        dm = (g8 <= int(np.percentile(g8, 10))).astype(np.uint8) * 255

        def _extract(mask):
            c = cv2.morphologyEx(mask, cv2.MORPH_OPEN, np.ones((3, 3), np.uint8))
            l = measure.label(c)
            return [p for p in measure.regionprops(l) if p.area >= min_area], c

        bp, bc = _extract(bm)
        dp, dc = _extract(dm)

        k = min(cluster_count, 8)
        pixels = g8.reshape(-1, 1).astype(np.float32)
        _, lk, centers = cv2.kmeans(
            pixels, k, None,
            (cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 200, 0.1),
            10, cv2.KMEANS_RANDOM_CENTERS,
        )
        lk_img = lk.reshape(g8.shape)

        bright_cov = round(float(np.sum(bc > 0)) / g.size * 100, 3)
        dark_cov   = round(float(np.sum(dc > 0)) / g.size * 100, 3)
        total_cov  = round(bright_cov + dark_cov, 3)

        result: ActiveSiteResult = {
            "cluster_count":       k,
            "bright_site_count":   len(bp),
            "dark_site_count":     len(dp),
            "total_site_count":    len(bp) + len(dp),
            "bright_coverage_pct": bright_cov,
            "dark_coverage_pct":   dark_cov,
            "total_coverage_pct":  total_cov,
            "bright_props":        bp,
            "dark_props":          dp,
            "bright_mask":         bc,
            "dark_mask":           dc,
            "centers":             centers,
            "g_norm":              g8,
            "kmeans_labels":       lk_img,
        }
        log.info("Active sites: bright=%d | dark=%d | total_cov=%.3f%%",
                 len(bp), len(dp), total_cov)
        return result


class AnalysisEngine:
    """Facade that holds analysers, current image and all results."""

    def __init__(self):
        self.por_analyzer   = PorosityAnalyzer()
        self.foul_analyzer  = FoulingAnalyzer()
        self.site_analyzer  = ActiveSiteAnalyzer()
        self.results:   Dict[str, Any] = {}
        self.img_path:  str            = ""
        self.calibration: ScaleCalibration = ScaleCalibration()  # smart scale object

    @property
    def original(self) -> Optional[np.ndarray]:
        return self.por_analyzer.original

    @property
    def gray(self) -> Optional[np.ndarray]:
        return self.por_analyzer.gray

    @property
    def meta(self) -> ImageMeta:
        return self.por_analyzer.meta

    def load_image(self, path: str) -> np.ndarray:
        self.img_path = path
        img = self.por_analyzer.load_image(path)
        self.foul_analyzer.load_image(path)
        self.site_analyzer.load_image(path)
        # Keep calibration width in sync with the actual loaded image
        self.calibration.image_width_px = self.por_analyzer.meta.width
        log.info("Calibration synced: image_width=%d px | nm/px=%.4f",
                 self.calibration.image_width_px, self.calibration.nm_per_px)
        return img

    def analyze_porosity(self, method="otsu", min_pore_px=10) -> PorosityResult:
        r = self.por_analyzer.analyze(method, min_pore_px, self.calibration)
        self.results["porosity"] = r
        return r

    def analyze_fouling(self, layer_side="top") -> FoulingResult:
        r = self.foul_analyzer.analyze(layer_side)
        self.results["fouling"] = r
        return r

    def analyze_active_sites(self, cluster_count=5) -> ActiveSiteResult:
        r = self.site_analyzer.analyze(cluster_count)
        self.results["active_sites"] = r
        return r

    def compare_images(self, p1: str, p2: str, method="otsu") -> ComparisonResult:
        a1, a2 = PorosityAnalyzer(), PorosityAnalyzer()
        a1.load_image(p1); a2.load_image(p2)
        # Each image may have different px count; build per-image calibration
        cal1 = ScaleCalibration(self.calibration.scale_value,
                                self.calibration.scale_unit,
                                a1.meta.width)
        cal2 = ScaleCalibration(self.calibration.scale_value,
                                self.calibration.scale_unit,
                                a2.meta.width)
        r1 = a1.analyze(method, cal=cal1)
        r2 = a2.analyze(method, cal=cal2)
        result: ComparisonResult = {
            "img1_porosity":   r1["porosity_pct"],
            "img2_porosity":   r2["porosity_pct"],
            "delta_porosity":  round(r2["porosity_pct"] - r1["porosity_pct"], 3),
            "img1_pore_count": r1["pore_count"],
            "img2_pore_count": r2["pore_count"],
            "img1_mean_diam":  r1["mean_diam_px"],
            "img2_mean_diam":  r2["mean_diam_px"],
            "r1": r1, "r2": r2,
        }
        self.results["comparison"] = result
        return result

    def export_json(self, path: str):
        """Export all scalar results + metadata to JSON."""
        payload: Dict[str, Any] = {
            "app_version": APP_VERSION,
            "exported_at": datetime.datetime.now().isoformat(),
            "image":  {
                "path":          self.img_path,
                "width":         self.meta.width,
                "height":        self.meta.height,
                "file_kb":       round(self.meta.file_size_kb, 1),
                "scale_value":   self.calibration.scale_value,
                "scale_unit":    self.calibration.scale_unit,
                "nm_per_px":     round(self.calibration.nm_per_px, 6),
                "um_per_px":     round(self.calibration.um_per_px, 9),
                "calibrated":    self.calibration.is_calibrated,
            },
            "modules": {}
        }
        for mod, data in self.results.items():
            payload["modules"][mod] = {
                k: v for k, v in data.items()
                if isinstance(v, (int, float, str, bool))
            }
        with open(path, "w", encoding="utf-8") as f:
            json.dump(payload, f, indent=2, ensure_ascii=False)
        log.info("JSON exported: %s", path)


