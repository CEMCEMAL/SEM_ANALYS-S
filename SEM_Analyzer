        self._mode_inds[val] = ind

        lbl = tk.Label(f, text=self.t(lang_key),
                       bg=C["bg_panel"], fg=C["text_md"], font=FT["body"])
        lbl.pack(side="left", anchor="w", pady=5)
        self._mode_labels[val] = lbl

        rb = tk.Radiobutton(f, variable=self.mode_var, value=val,
                            bg=C["bg_panel"], fg=C["bg_panel"],
                            selectcolor=C["bg_panel"],
                            activebackground=C["bg_panel"],
                            relief="flat", bd=0, indicatoron=True)
        rb.pack(side="right")

        # Tıklama için frame'e de bind et
        def on_click(_=None):
            self.mode_var.set(val)
        f.bind("<Button-1>", on_click)
        lbl.bind("<Button-1>", on_click)

        def refresh(*_):
            for v2, i2 in self._mode_inds.items():
                c2 = dict((v,c) for v,lk,c in self._modes).get(v2, C["bg_input"])
                i2.configure(bg=c2 if self.mode_var.get()==v2 else C["bg_input"])
        self.mode_var.trace_add("write", refresh)

