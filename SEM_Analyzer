        self._mode_labels = {}  # mode_val -> label_widget
        self._mode_inds   = {}  # mode_val -> indicator frame

        self._build()
        self._apply_ttk()

    # ── i18n shorthand ────────────────────────────────────────────────────────
    def t(self, key):
        return LANG[self._lang].get(key, key)

    def _i18n_reg(self, widget, attr, lang_key):
        """Dil değişiminde güncellenecek widget'ları kaydet."""
        self._dyn[id(widget)] = (widget, attr, lang_key)

    def _apply_lang(self):
        """Tüm kayıtlı widget'ları mevcut dile göre güncelle."""
        for wid, (widget, attr, key) in self._dyn.items():
            try:
                widget.configure(**{attr: self.t(key)})
            except Exception:
                pass
        # Mode radio etiketleri
        for val, lbl_w in self._mode_labels.items():
            key = {"Porosity":"mode_por","Fouling Layer":"mode_foul",
                   "Active Sites":"mode_sites","Comparison":"mode_comp"}[val]
            lbl_w.configure(text=self.t(key))
        # Metrik kart etiketleri
        for k, (mc, lk, uk) in self._mc_meta.items():
            mc.relabel(self.t(lk), self.t(uk))
        # Tab etiketleri
        self.nb.tab(self.tab_r, text=self.t("tab_results"))
        self.nb.tab(self.tab_c, text=self.t("tab_charts"))
        self.nb.tab(self.tab_l, text=self.t("tab_log"))
        # Topbar subtitle & status
        self._sub_lbl.configure(text=self.t("app_sub"))
        self._status_lbl.configure(text=" " + self.t("status_ready"))
        # Results default text
        self._rt_default()

