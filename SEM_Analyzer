        self.img_canvas.create_text(cx, cy - 20, text="⊡",
                                    font=(F_UI, 34), fill=C["border"])
        self.img_canvas.create_text(cx, cy + 20, font=FT["small"],
                                    fill=C["text_lo"], text=self.t("ph_line1"))
        self.img_canvas.create_text(cx, cy + 38, font=FT["small"],
                                    fill=C["sep"],     text=self.t("ph_line2"))
        self.img_canvas.create_text(cx, cy + 56, font=FT["mono_s"],
