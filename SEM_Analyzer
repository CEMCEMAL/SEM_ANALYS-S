    def _load_file(self, path: str):
        """Load primary image — called from browse, drop, or recent menu."""
        try:
            self.engine.load_image(path)
        except Exception as e:
            messagebox.showerror(self.t("dlg_err"), str(e))
            return
        self.img_path.set(path)
        pil = Image.fromarray(cv2.cvtColor(self.engine.original, cv2.COLOR_BGR2RGB))
        self.img_canvas.show_pil(pil)
        # Info bar overlay — append [cropped] if bar was removed
        orig_full = cv2.imread(path, cv2.IMREAD_UNCHANGED)
        full_h    = orig_full.shape[0] if orig_full is not None else 0
        crop_note = ""
        if full_h > 0 and self.engine.meta.height < full_h:
            removed   = full_h - self.engine.meta.height
            crop_note = f"  · ✂ bilgi çubuğu kırpıldı ({removed} px)"
        self.img_canvas.create_rectangle(0, 0, self.img_canvas.winfo_width(), 22,
                                         fill="#00000077", outline="")
        self.img_canvas.create_text(10, 11, anchor="w",
                                    text=self.engine.meta.label() + crop_note,
                                    font=FT["mono_s"], fill=C["text_lo"])
        self._log_add(self.t("log_loaded") + Path(path).name, "ok")
        self._recent = add_recent(path, self._recent)
        save_recent(self._recent)
        self._rebuild_recent_menu()
        # Try to auto-detect scale from SEM info bar
        self.after(80, lambda p=path: self._auto_detect_scale(p))

    def _show_cv2(self, bgr: np.ndarray):
        rgb = cv2.cvtColor(bgr, cv2.COLOR_BGR2RGB)
        pil = Image.fromarray(rgb)
        self.img_canvas.show_pil(pil)

