                         highlightbackground=C["border"], highlightthickness=1, **kw)
        self._accent = accent or C["teal"]
        self._top_bar = tk.Frame(self, bg=self._accent, height=2)
        self._top_bar.pack(fill="x")
        inner = tk.Frame(self, bg=C["bg_card"])
        inner.pack(fill="both", expand=True, padx=12, pady=8)
        self._var   = tk.StringVar(value="--")
        self._lbl_v = tk.Label(inner, textvariable=self._var,
                               font=(F_NUM,15,"bold"), fg=C["text_hi"], bg=C["bg_card"])
        self._lbl_v.pack(anchor="w")
        self._lbl_u = tk.Label(inner, text=unit, font=FT["small"], fg=self._accent, bg=C["bg_card"])
        self._lbl_u.pack(anchor="w")
        self._lbl_l = tk.Label(inner, text=label, font=FT["small"], fg=C["text_lo"], bg=C["bg_card"])
        self._lbl_l.pack(anchor="w", pady=(3,0))

    def set(self, v):
        self._var.set(str(v))

    def relabel(self, label, unit):
        self._lbl_l.configure(text=label)
        self._lbl_u.configure(text=unit)


class ScrollFrame(tk.Frame):
    def __init__(self, parent, bg=None, **kw):
        bg = bg or C["bg_panel"]
        super().__init__(parent, bg=bg, **kw)
        self._cv = tk.Canvas(self, bg=bg, highlightthickness=0, bd=0)
        self._sb = tk.Scrollbar(self, orient="vertical", command=self._cv.yview)
        self._cv.configure(yscrollcommand=self._sb.set)
        self._sb.pack(side="right", fill="y")
        self._cv.pack(side="left", fill="both", expand=True)
        self.inner = tk.Frame(self._cv, bg=bg)
        self._win  = self._cv.create_window((0,0), window=self.inner, anchor="nw")
        self.inner.bind("<Configure>", lambda e: self._cv.configure(
            scrollregion=self._cv.bbox("all")))
        self._cv.bind("<Configure>", lambda e: self._cv.itemconfig(
            self._win, width=e.width))
        for w in (self._cv, self.inner):
            w.bind("<MouseWheel>", lambda e: self._cv.yview_scroll(
                int(-1*(e.delta/120)), "units"))


