# ─── ANALYSIS ENGINE ──────────────────────────────────────────────────────────

class AnalysisEngine:
    def __init__(self):
        self.original = None
        self.gray     = None
        self.results  = {}
        self.img_path = None

    def load_image(self, path):
        img = cv2.imread(path)
        if img is None:
            try:
                pil = Image.open(path).convert("RGB")
                img = cv2.cvtColor(np.array(pil), cv2.COLOR_RGB2BGR)
            except Exception as e:
                raise ValueError(f"Cannot load image: {path}\n({e})")
        if img is None:
            raise ValueError(f"Cannot load image: {path}")
        self.original = img
        self.gray     = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        self.img_path = path
        return img

    def analyze_porosity(self, method="otsu", min_pore_px=10):
        g = self.gray.copy()
        if method == "otsu":
            thresh, mask = cv2.threshold(g, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
        elif method == "adaptive":
            mask   = cv2.adaptiveThreshold(g, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
                                           cv2.THRESH_BINARY_INV, 31, 5)
            thresh = None
        elif method == "triangle":
            thresh, mask = cv2.threshold(g, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_TRIANGLE)
        else:
            raise ValueError(f"Unknown method: {method}")
        kernel     = np.ones((3, 3), np.uint8)
        mask_clean = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel, iterations=2)
        labeled    = measure.label(mask_clean)
        props      = [p for p in measure.regionprops(labeled) if p.area >= min_pore_px]
        valid_mask = np.zeros_like(mask_clean)
        for p in props: valid_mask[labeled == p.label] = 255
        areas      = np.array([p.area for p in props])
        diameters  = 2 * np.sqrt(areas / np.pi) if len(areas) else np.array([])
        eccs       = np.array([p.eccentricity for p in props])
        result = {
            "method":         method,
            "threshold":      thresh if thresh is not None else "adaptive",
            "porosity_pct":   round(int(np.sum(valid_mask > 0)) / g.size * 100, 3),
            "pore_count":     len(props),
            "mean_diam_px":   round(float(np.mean(diameters)) if len(diameters) else 0, 2),
            "std_diam_px":    round(float(np.std(diameters))  if len(diameters) else 0, 2),
            "max_diam_px":    round(float(np.max(diameters))  if len(diameters) else 0, 2),
            "min_diam_px":    round(float(np.min(diameters))  if len(diameters) else 0, 2),
            "mean_eccentric": round(float(np.mean(eccs))      if len(eccs)       else 0, 3),
            "mask":           valid_mask, "props": props,
            "areas": areas, "diameters": diameters,
        }
        self.results["porosity"] = result
        return result

    def analyze_fouling(self, layer_side="top"):
        g    = self.gray.copy()
        h, w = g.shape
        profile     = np.mean(g, axis=1) if layer_side in ("top","bottom") else np.mean(g, axis=0)
        sobelx      = cv2.Sobel(g, cv2.CV_64F, 1, 0, ksize=5)
        sobely      = cv2.Sobel(g, cv2.CV_64F, 0, 1, ksize=5)
        edge_map    = np.sqrt(sobelx**2 + sobely**2)
        canny_edges = canny(g.astype(float) / 255.0, sigma=2.0)
        smooth_grad = ndimage.gaussian_filter1d(np.abs(np.gradient(profile)), sigma=5)
        if layer_side == "top":
            idx = int(np.argmax(smooth_grad[:h//2])); thick = idx
        elif layer_side == "bottom":
            idx = h - int(np.argmax(smooth_grad[h//2:][::-1])) - 1; thick = h - idx
        else:
            idx = int(np.argmax(smooth_grad)); thick = idx
        lr = g[:idx, :] if layer_side == "top" else g[idx:, :]
        mr = g[idx:, :] if layer_side == "top" else g[:idx, :]
        result = {
            "layer_side":              layer_side,
            "interface_row_px":        idx,
            "fouling_thickness_px":    thick,
            "fouling_thickness_pct":   round(thick / h * 100, 2),
            "layer_mean_intensity":    round(float(np.mean(lr)), 2) if lr.size else 0,
            "membrane_mean_intensity": round(float(np.mean(mr)), 2) if mr.size else 0,
            "contrast_ratio":          round(float(np.std(g)), 3),
            "profile": profile, "smooth_grad": smooth_grad,
            "edge_map": edge_map, "canny_edges": canny_edges,
        }
        self.results["fouling"] = result
        return result

    def analyze_active_sites(self, cluster_count=5, min_area=5):
        g      = self.gray.copy()
        g8     = (exposure.equalize_adapthist(g, clip_limit=0.03) * 255).astype(np.uint8)
        bm     = (g8 >= int(np.percentile(g8, 90))).astype(np.uint8) * 255
        dm     = (g8 <= int(np.percentile(g8, 10))).astype(np.uint8) * 255
        def extract(mask):
            c = cv2.morphologyEx(mask, cv2.MORPH_OPEN, np.ones((3,3), np.uint8))
            l = measure.label(c)
            return [p for p in measure.regionprops(l) if p.area >= min_area], c
        bp, bc = extract(bm); dp, dc = extract(dm)
        pixels = g8.reshape(-1,1).astype(np.float32)
        k = min(cluster_count, 8)
        _, lk, centers = cv2.kmeans(pixels, k, None,
            (cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 200, 0.1),
            10, cv2.KMEANS_RANDOM_CENTERS)
        result = {
            "cluster_count":       k,
            "bright_site_count":   len(bp),
            "dark_site_count":     len(dp),
            "total_site_count":    len(bp) + len(dp),
            "bright_coverage_pct": round(float(np.sum(bc>0)) / g.size * 100, 3),
            "dark_coverage_pct":   round(float(np.sum(dc>0)) / g.size * 100, 3),
            "bright_props": bp, "dark_props": dp,
            "bright_mask": bc, "dark_mask": dc,
            "centers": centers, "g_norm": g8,
        }
        self.results["active_sites"] = result
        return result

    def compare_images(self, p1, p2, method="otsu"):
        e1, e2 = AnalysisEngine(), AnalysisEngine()
        e1.load_image(p1); e2.load_image(p2)
        r1 = e1.analyze_porosity(method); r2 = e2.analyze_porosity(method)
        return {
            "img1_porosity":   r1["porosity_pct"],
            "img2_porosity":   r2["porosity_pct"],
            "delta_porosity":  round(r2["porosity_pct"] - r1["porosity_pct"], 3),
            "img1_pore_count": r1["pore_count"],
            "img2_pore_count": r2["pore_count"],
            "img1_mean_diam":  r1["mean_diam_px"],
            "img2_mean_diam":  r2["mean_diam_px"],
            "r1": r1, "r2": r2,
        }


